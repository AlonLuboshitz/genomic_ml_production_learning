# Python cache files — unnecessary bloat
__pycache__/
*.pyc

# Virtual environment — would be huge; we install fresh inside
.venv/
venv/

# Environment config — don't leak secrets
.env

# SQLite database — we want a fresh one or a mounted volume
*.db

# MLflow experiment data — too large, should be mounted or stored remotely
mlruns/

# Trained models — only include the baseline needed for the API
models/
!models/baseline.pkl

# Git history — not needed in the container
.git/

# OS files
.DS_Store
Thumbs.db